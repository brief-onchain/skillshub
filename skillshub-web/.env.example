# Local/Server shared env
PORT=3000

# Public wallet + NFA mint config
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=
NEXT_PUBLIC_BSC_RPC_URL=https://bsc-dataseed.binance.org/
NEXT_PUBLIC_NFA_CONTRACT_ADDRESS=
NFA_CONTRACT_ADDRESS=
NFA_OWNER=
NFA_TREASURY=
NFA_SALE_ACTIVE=true
NFA_BASE_URI=
NFA_CONTRACT_URI=
NEXT_PUBLIC_NFA_PAYMENT_TOKEN_ADDRESS=
NFA_PAYMENT_TOKEN_ADDRESS=
NEXT_PUBLIC_NFA_PAYMENT_TOKEN_SYMBOL=SKILL
NFA_PAYMENT_TOKEN_SYMBOL=SKILL
NEXT_PUBLIC_NFA_PAYMENT_TOKEN_DECIMALS=18
NFA_PAYMENT_TOKEN_DECIMALS=18
NEXT_PUBLIC_NFA_DIVIDEND_CONTRACT_ADDRESS=
NFA_DIVIDEND_CONTRACT_ADDRESS=
NFA_DIVIDEND_REWARD_TOKEN=0x0000000000000000000000000000000000000000

# Dividend operator / cron
CRON_SECRET=
# Owner signer used only to create snapshot rounds.
NFA_DIVIDEND_OPERATOR_PRIVATE_KEY=
# Dedicated funding wallet used only to send BNB into the dividend contract.
NFA_DIVIDEND_REFILL_PRIVATE_KEY=
NFA_DIVIDEND_GAS_RESERVE_WEI=10000000000000000
NFA_DIVIDEND_SKILL_PER_SHARE=100000
NFA_DIVIDEND_SNAPSHOT_DIR=
# Leave empty if your external tax script POSTs an explicit amount each time.
NFA_DIVIDEND_REFILL_AMOUNT_WEI=
NFA_DIVIDEND_REFILL_AMOUNT=

# LLM config for NFA chat
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=openai/gpt-4o-mini

# Optional remote AI skill gateway for playground proxy mode
SKILLS_API_BASE=
SKILLS_API_PATH=/skills/run
SKILLS_API_KEY=
SKILLS_API_MODEL=gpt-4.1-mini

# Optional frontend base (leave empty for same-origin)
NEXT_PUBLIC_DEFAULT_API_BASE=

# GitHub repo base for skills deep-links in UI
# Example: https://github.com/your-org/bsc-skiller-brain
NEXT_PUBLIC_SKILLS_GITHUB_REPO=https://github.com/brief-onchain/skills-lab
